API_HOST=0.0.0.0
API_PORT=8000
# Logging: INFO shows processing_metrics / web_scenario_* from src.* (default INFO)
LOG_LEVEL=INFO
# Cookie session for Jinja2 web UI (set a long random string in production)
SESSION_SECRET=
# Optional: override directory for web UI result tokens (default: data/web_ui_results)
# DOCUMIND_WEB_RESULT_DIR=
# Shared processing lock (SQLite) for dm-api + dm-bot (default: data/processing_lock.sqlite3)
# DOCUMIND_PROCESSING_LOCK_DB=
# Consider lock as stale after N seconds (crash recovery; default: 3600)
# DOCUMIND_PROCESSING_LOCK_STALE_SECONDS=3600
TELEGRAM_BOT_TOKEN=
# Optional: deep link for web UI "Open Telegram bot" button
TELEGRAM_BOT_URL=https://t.me/vs_DocuMind_bot
PROXYAPI_API_KEY=
GOOGLE_OAUTH_CLIENT_SECRET_JSON=
GOOGLE_DRIVE_FOLDER_ID=
